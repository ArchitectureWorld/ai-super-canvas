# Copy this file to .env before running Docker Compose.

# Bind to 127.0.0.1 when a trusted reverse proxy or Tailscale fronts the app.
# Set to 0.0.0.0 only when direct LAN access is intentionally required.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=3000
APP_OWNER_ID=local-owner

POSTGRES_USER=canvas
# Use a long URL-safe value containing letters, numbers, hyphens, or underscores.
# Example generator: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
POSTGRES_PASSWORD=replace-with-a-long-url-safe-random-password
POSTGRES_DB=canvas

OPENAI_API_KEY=
OPENAI_MODEL=

# All selectable models for canvas blocks. This catalog is safe to expose to the browser;
# keep provider API keys private in this same environment file.
AI_AVAILABLE_MODELS=gpt-5,gpt-5-mini,deepseek-chat
AI_DEFAULT_MODEL=gpt-5

NEXT_TELEMETRY_DISABLED=1
