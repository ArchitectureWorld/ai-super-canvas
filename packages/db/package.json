  },
  "dependencies": {
    "@ai-super-canvas/core": "workspace:*",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
