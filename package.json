{
  "name": "ai-super-canvas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.12.0 <12"
  },
  "scripts": {
    "dev": "pnpm --filter @ai-super-canvas/web dev",
    "build": "pnpm -r --if-present build",
    "start": "pnpm --filter @ai-super-canvas/web start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @ai-super-canvas/db db:generate",
    "db:migrate": "pnpm --filter @ai-super-canvas/db db:migrate",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=200",
    "test:integration:docker": "bash ./scripts/test-integration.sh"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
